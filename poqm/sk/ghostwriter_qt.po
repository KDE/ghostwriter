msgid "SHIFT+Backspace"
msgstr "SHIFT+Backspace"

#: src/appactions.cpp:221
msgctxt "ghostwriter::AppActions|"
msgid "Toggles Hemingway mode."
msgstr "Prepne Hemingwayov režim."

#: src/appactions.cpp:223
msgctxt "ghostwriter::AppActions|"
msgid ""
"Hemingway mode disables the backspace and delete keys to help you resist the "
"temptation to edit your document as you write."
msgstr ""
"Hemingwayov režim deaktivuje klávesy Backspace a Delete, aby vám pomohol "
"odolať pokušeniu upravovať dokument počas písania."

#: src/appactions.cpp:226
msgctxt "ghostwriter::AppActions|"
msgid "Dark Mode"
msgstr "Tmavý režim"

#: src/appactions.cpp:227
msgctxt "ghostwriter::AppActions|"
msgid "Enables/disables the current theme's dark color scheme."
msgstr "Povolí/zakáže tmavú farebnú schému aktuálnej témy."

#: src/appactions.cpp:229
msgctxt "ghostwriter::AppActions|"
msgid ""
"<p>Enables/disables the current theme's dark color scheme.</p><p>If the "
"current theme does not support a dark color scheme, then this option will "
"have no effect.</p>"
msgstr ""
"<p>Povolí/zakáže tmavú farebnú schému aktuálnej témy.</p><p>Ak aktuálna téma "
"nepodporuje tmavú farebnú schému, táto voľba nebude mať žiadny účinok.</p>"

#: src/appactions.cpp:233
msgctxt "ghostwriter::AppActions|"
msgid "Show Sidebar"
msgstr "Zobraziť bočný panel"

#: src/appactions.cpp:233
msgctxt "ghostwriter::AppActions|"
