msgctxt "ghostwriter::AppActions|"
msgid "CTRL+J"
msgstr "CTRL+J"

#: src/appactions.cpp:236
msgctxt "ghostwriter::AppActions|"
msgid "Shows the document outline."
msgstr "Zobrazí osnovu dokumentu."

#: src/appactions.cpp:238
msgctxt "ghostwriter::AppActions|"
msgid ""
"<p>Shows the document outline.</p><p>Use the mouse plus left click on a "
"heading in the document, or else the up and down arrows on the keyboard plus "
"the ENTER key, to jump to different locations within the current document.</"
"p>"
msgstr ""
"<p>Zobrazí osnovu dokumentu.</p><p>Použite myš a ľavé kliknutie na nadpis v "
"dokumente, alebo šípky nahor a nadol na klávesnici spolu s klávesom ENTER, "
"na preskočenie na rôzne miesta v aktuálnom dokumente.</p>"

