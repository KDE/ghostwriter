msgid "- Bullet List"
msgstr "- Zoznam odrážok"

#: src/appactions.cpp:140
msgctxt "ghostwriter::AppActions|"
msgid "CTRL+-"
msgstr "CTRL+-"

#: src/appactions.cpp:142
msgctxt "ghostwriter::AppActions|"
msgid ""
"Formats the current line or selected lines as a bullet point list with a "
"minus sign (-)."
msgstr ""
"Naformátuje aktuálny riadok alebo vybrané riadky ako odrážkový zoznam so "
"znamienkom mínus (-)."

#: src/appactions.cpp:145
msgctxt "ghostwriter::AppActions|"
msgid "+ Bullet List"
msgstr "+ Zoznam odrážok"

#: src/appactions.cpp:145
msgctxt "ghostwriter::AppActions|"
msgid "CTRL++"
msgstr "CTRL++"

#: src/appactions.cpp:147
msgctxt "ghostwriter::AppActions|"
msgid ""
"Formats the current line or selected lines as a bullet point list with a "
"plus sign (+)."
msgstr ""
"Naformátuje aktuálny riadok alebo vybrané riadky ako odrážkový zoznam so "
"znamienkom plus (+)."

#: src/appactions.cpp:150
msgctxt "ghostwriter::AppActions|"
msgid "1. Numbered List"
msgstr "1. Číslovaný zoznam"

#: src/appactions.cpp:150
msgctxt "ghostwriter::AppActions|"
msgid "CTRL+1"
msgstr "CTRL+1"

#: src/appactions.cpp:152 src/appactions.cpp:165
msgctxt "ghostwriter::AppActions|"
msgid "Formats the current line or selected lines as a numbered list."
msgstr "Naformátuje aktuálny riadok alebo vybrané riadky ako číslovaný zoznam."

#: src/appactions.cpp:155
msgctxt "ghostwriter::AppActions|"
msgid ""
"<p>Formats the current line or selected lines as a numbered list.</"
"p><p>Example:</p><p>1. item one<br/>2. item two<br/>3. item three<br/></p>"
msgstr ""
"<p>Naformátuje aktuálny riadok alebo vybrané riadky ako číslovaný zoznam.</"
"p><p>Príklad:</p><p>1. položka jedna<br/>2. položka dva<br/>3. položka "
"tri<br/></p>"

#: src/appactions.cpp:163
msgctxt "ghostwriter::AppActions|"
msgid "1) Numbered List"
msgstr "1) Číslovaný zoznam"

#: src/appactions.cpp:163
msgctxt "ghostwriter::AppActions|"
msgid "CTRL+0"
msgstr "CTRL+0"

#: src/appactions.cpp:168
msgctxt "ghostwriter::AppActions|"
msgid ""
"<p>Formats the current line or selected lines as a numbered list.</"
"p><p>Example:</p><p>1) item one<br/>2) item two<br/>3) item three<br/></"
"p><p>Note that this numbering format is not supported by all Markdown "
"processors and is not part of CommonMark.</p>"
msgstr ""
"<p>Naformátuje aktuálny riadok alebo vybrané riadky ako číslovaný zoznam.</"
"p><p>Príklad:</p><p>1) položka jedna<br/>2) položka dva<br/>3) položka "
"tri<br/></p><p>Tento formát číslovania nie je podporovaný všetkými "
"procesormi Markdown a nie je súčasťou CommonMark.</p>"

#: src/appactions.cpp:178
msgctxt "ghostwriter::AppActions|"
msgid "Task List"
msgstr "Zoznam úloh"

#: src/appactions.cpp:178
msgctxt "ghostwriter::AppActions|"
msgid "CTRL+T"
msgstr "CTRL+T"

#: src/appactions.cpp:179
msgctxt "ghostwriter::AppActions|"
msgid "Formats the current line or selected lines as a task list."
msgstr "Naformátuje aktuálny riadok alebo vybrané riadky ako zoznam úloh."

#: src/appactions.cpp:181
msgctxt "ghostwriter::AppActions|"
msgid ""
"<p>Formats the current line or selected lines as a task list.</p><p>Example:"
"</p><p>- [ ] item one<br/>- [ ] item two<br/>- [ ] item three<br/></"
"p><p>Note that task lists are not supported by all Markdown processors and "
"are not part of CommonMark.</p>"
msgstr ""
"<p>Naformátuje aktuálny riadok alebo vybrané riadky ako zoznam úloh.</"
"p><p>Príklad:</p><p>- [ ] položka jedna<br/>- [ ] položka dva<br/>- [ ] "
"položka tri<br/></p><p>Zoznamy úloh nie sú podporované všetkými procesormi "
"Markdown a nie sú súčasťou CommonMark.</p>"

#: src/appactions.cpp:191
msgctxt "ghostwriter::AppActions|"
msgid "Toggle Task(s) Complete"
msgstr "Prepnúť dokončenie úloh(y)"

#: src/appactions.cpp:191
msgctxt "ghostwriter::AppActions|"
msgid "CTRL+D"
msgstr "CTRL+D"

#: src/appactions.cpp:193
msgctxt "ghostwriter::AppActions|"
msgid ""
"Toggle the current task item or selected task items as complete or "
"incomplete."
msgstr ""
"Prepnúť aktuálnu položku úlohy alebo vybrané položky úloh ako dokončené "
"alebo nedokončené."

#: src/appactions.cpp:196
msgctxt "ghostwriter::AppActions|"
msgid ""
"<p>Toggle the state of the current task item or selected task items from a "
"task list as complete or incomplete.</p><p>Applying this action to an "
"incomplete task item in a task list will result in placing an 'x' between "
"its brackets, like so:</p><p>- [x] item one<br/></p><p>Likewise, applying "
"this action to an completed task item in a task list will result in removing "
"its 'x' between its brackets, like so:</p><p>- [ ] item one<br/></p><p>Note "
"that task lists are not supported by all Markdown processors and are not "
"part of CommonMark.</p>"
msgstr ""
"<p>Prepne stav aktuálnej položky úlohy alebo vybraných položiek úloh zo "
"zoznamu úloh ako dokončené alebo nedokončené.</p><p>Použitie tejto akcie na "
"nedokončenú položku úlohy v zozname úloh spôsobí vloženie znaku 'x' medzi "
"jej zátvorky, napríklad takto:</p><p>- [x] položka jedna<br/></p><p>Podobne, "
"použitie tejto akcie na dokončenú položku úlohy v zozname úloh spôsobí "
"odstránenie znaku 'x' medzi jej zátvorkami, napríklad takto:</p><p>- [ ] "
"položka jedna<br/></p><p>Upozorňujeme, že zoznamy úloh nie sú podporované "
"všetkými procesormi Markdown a nie sú súčasťou CommonMark.</p>"

